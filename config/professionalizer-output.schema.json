    },
    "in_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "target_files_or_areas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "execution_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workspace_hygiene": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_deliverables": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "executor_prompt": {
      "type": "string"
    },
    "executor_prompt_preview": {
      "type": "string"
    },
    "schema_validation_ok": {
      "type": "boolean"
    },
    "fallback_reason": {
      "type": "string"
    },
    "channel_strategy": {
      "type": "string"
    },
    "suggested_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_language": {
      "type": "string",
      "enum": [
        "zh-CN",
        "en"
      ]
    }
  }
}
