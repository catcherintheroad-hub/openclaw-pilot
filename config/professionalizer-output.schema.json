      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "project_goal": {
      "type": "string"
    },
    "core_thesis": {
      "type": "string"
    },
    "pilot_id": {
      "type": "string"
    },
    "current_stage_id": {
      "type": "string"
    },
    "current_stage_name": {
      "type": "string"
